---
import { diensten } from "../data/site";
import SectionHead from "./SectionHead.astro";

const icons: Record<string, string> = {
  restauratie: '<path d="M3 21h18M6 21V9l6-4 6 4v12M9 21v-5h6v5"/><path d="M10 12h4"/>',
  woning: '<path d="M3 11.5 12 4l9 7.5M5 10v11h14V10"/><path d="M9.5 21v-6h5v6"/>',
  utiliteit: '<path d="M3 21h18M5 21V5h9v16M14 21V9h5v12M8 9h2M8 13h2M8 17h2"/>',
  winkel: '<path d="M4 9h16l-1-4H5L4 9Z"/><path d="M5 9v11h14V9M9 20v-5h6v5"/>',
  comfort: '<path d="M12 21s-7-4.5-9-9a4.5 4.5 0 0 1 8-3 4.5 4.5 0 0 1 8 3c-2 4.5-7 9-7 9Z"/>',
  duurzaam: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.5 19 2c1 3 1.5 8-1 11.5A7 7 0 0 1 11 20Z"/><path d="M2 22c2-4 4-6 8-8"/>',
  onderhoud: '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.3 2.3-2-2 2.3-2.3Z"/>',
  thuisfront: '<path d="M3 11.5 12 4l9 7.5M5 10v11h14V10"/><path d="M12 14a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z"/>',
};
---

<section id="diensten" class="ctx-light grain relative overflow-hidden py-24 sm:py-32" style="background:var(--color-steen);">
  <div class="container-edge relative">
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-end">
      <SectionHead index="02" label="Disciplines" title="Eén bouwpartner,<br />voor elke opgave." />
      <p class="lede reveal max-w-md lg:pb-2">
        Of het nu gaat om een eeuwenoud monument of een nieuw bedrijfspand: we hebben de
        vakmensen, de ervaring en de erkenningen in huis. Acht disciplines, onder één dak.
      </p>
    </div>

    <div class="mt-14 grid border-t border-[var(--line)] md:grid-cols-2 md:gap-x-12">
      {
        diensten.map((d, i) => (
          <article class="dienst group reveal relative flex gap-5 border-b border-[var(--line)] py-7">
            <span class="ix shrink-0 pt-1.5">{`0${i + 1}`}</span>
            <div class="flex-1">
              <div class="flex items-start justify-between gap-4">
                <h3 class="h-card font-semibold transition-colors duration-300 group-hover:text-[var(--color-navy)]">{d.title}</h3>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-[var(--fg-muted)] opacity-50 transition-all duration-300 group-hover:text-[var(--color-geel-deep)] group-hover:opacity-100" set:html={icons[d.icon]} />
              </div>
              <p class="mt-2 max-w-md text-sm leading-relaxed text-[var(--fg-soft)]">{d.blurb}</p>
            </div>
            <span class="absolute left-0 top-0 h-px w-0 bg-[var(--color-geel)] transition-all duration-500 group-hover:w-full" style="margin-top:-1px;"></span>
          </article>
        ))
      }
    </div>
  </div>
</section>
