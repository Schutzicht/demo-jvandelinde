---
import { projecten, projectCategories } from "../data/site";
import SectionHead from "./SectionHead.astro";
const filters = ["Alle", ...projectCategories];
---

<section id="projecten" class="ctx-light relative py-24 sm:py-32">
  <div class="container-edge">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHead index="03" label="Gerealiseerd werk" title="Honderden projecten,<br />door heel Zeeland." />

      <div id="proj-filters" class="reveal flex flex-wrap gap-x-1.5 gap-y-2">
        {
          filters.map((f, i) => (
            <button class={`proj-filter ${i === 0 ? "is-active" : ""}`} data-filter={f}>
              {f}
            </button>
          ))
        }
      </div>
    </div>

    <div id="proj-grid" class="mt-14 grid grid-flow-row-dense gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        projecten.map((p, i) => (
          <article
            class={`proj-card group reveal ${p.featured ? "sm:col-span-2" : ""}`}
            data-cat={p.category}
          >
            <a href="#contact" class="block">
              <div class="plate relative" style={`aspect-ratio:${p.featured ? "16/10" : "4/5"};`}>
                <img
                  src={p.image}
                  alt={`${p.title}, ${p.place}`}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.05]"
                  loading="lazy" width="900" height="700"
                />
                <span class="absolute right-4 top-4 grid h-9 w-9 translate-y-1 place-items-center rounded-full bg-white/90 text-[var(--color-navy)] opacity-0 transition-all duration-400 group-hover:translate-y-0 group-hover:opacity-100">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
                </span>
              </div>
              <div class="mt-4 flex items-baseline justify-between gap-4 border-t border-[var(--line)] pt-3.5">
                <span class="label"><span class="label-accent">N° {`0${i + 1}`}</span> &nbsp; {p.category}</span>
                <span class="label">{p.place}</span>
              </div>
              <h3 class="proj-title mt-2 inline serif text-[1.35rem] font-semibold leading-tight">{p.title}</h3>
              {p.featured && <p class="mt-2 max-w-lg text-sm leading-relaxed text-[var(--fg-soft)]">{p.blurb}</p>}
            </a>
          </article>
        ))
      }
    </div>

    <p id="proj-empty" class="mt-10 hidden text-center text-[var(--fg-muted)]">Geen projecten in deze categorie.</p>
  </div>
</section>

<style>
  .proj-filter {
    font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em;
    border-radius: 99px; border: 1px solid var(--border); color: var(--fg-soft);
    background: transparent; padding: 0.5rem 1rem; transition: all 0.3s var(--ease-out-soft);
  }
  .proj-filter:hover { border-color: color-mix(in srgb, var(--color-navy) 40%, var(--border)); color: var(--color-navy); }
  .proj-filter.is-active { background: var(--color-navy); border-color: var(--color-navy); color: #fff; }

  .proj-title { background-image: linear-gradient(var(--color-geel), var(--color-geel)); background-repeat: no-repeat; background-position: 0 100%; background-size: 0 2px; transition: background-size 0.5s var(--ease-out-soft); padding-bottom: 2px; }
  .proj-card:hover .proj-title { background-size: 100% 2px; }
  .proj-card { transition: opacity 0.4s ease; }
  .proj-card.is-hidden { display: none; }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".proj-filter");
  const cards = document.querySelectorAll<HTMLElement>(".proj-card");
  const empty = document.getElementById("proj-empty");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter;
      filterBtns.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      let shown = 0;
      cards.forEach((c) => {
        const match = f === "Alle" || c.dataset.cat === f;
        c.classList.toggle("is-hidden", !match);
        if (match) shown++;
      });
      empty?.classList.toggle("hidden", shown > 0);
    });
  });
</script>
