---
import { projecten, projectCategories } from "../data/site";
const filters = ["Alle", ...projectCategories];
---

<section id="projecten" class="ctx-light relative py-24 sm:py-32">
  <div class="container-edge">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl reveal">
        <p class="eyebrow">Gerealiseerd werk</p>
        <h2 class="display h-section mt-5">Honderden projecten,<br />door heel Zeeland.</h2>
        <p class="lede mt-5">
          Een greep uit ons werk, van monumentale restauratie tot strakke nieuwbouw. Filter
          op het type project dat u bezighoudt.
        </p>
      </div>

      <!-- Filters -->
      <div id="proj-filters" class="flex flex-wrap gap-2 reveal">
        {
          filters.map((f, i) => (
            <button
              class={`proj-filter rounded-full border px-4 py-2 text-sm font-medium transition-all duration-300 ${i === 0 ? "is-active" : ""}`}
              data-filter={f}
            >
              {f}
            </button>
          ))
        }
      </div>
    </div>

    <div id="proj-grid" class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projecten.map((p) => (
          <article
            class="proj-card group reveal relative overflow-hidden rounded-2xl"
            data-cat={p.category}
            style="aspect-ratio:4/3;"
          >
            <img
              src={p.image}
              alt={`${p.title}, ${p.place}`}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.1s] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.06]"
              loading="lazy" width="800" height="600"
            />
            <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(10,35,66,0.92) 6%, rgba(10,35,66,0.18) 52%, rgba(10,35,66,0.05) 100%);"></div>
            <span class="absolute left-4 top-4 rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-wider" style="background:var(--color-geel);color:var(--color-navy-deep);">
              {p.category}
            </span>
            <div class="absolute inset-x-0 bottom-0 p-5">
              <h3 class="font-display text-xl font-semibold text-white" style="font-family:var(--font-display);">{p.title}</h3>
              <p class="mt-0.5 flex items-center gap-1.5 text-sm text-white/75">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-6-5.7-6-10a6 6 0 1 1 12 0c0 4.3-6 10-6 10Z"/><circle cx="12" cy="11" r="2"/></svg>
                {p.place}
              </p>
              <p class="proj-blurb mt-3 max-w-md text-sm leading-relaxed text-white/0">{p.blurb}</p>
            </div>
          </article>
        ))
      }
    </div>

    <p id="proj-empty" class="mt-10 hidden text-center text-[var(--fg-muted)]">
      Geen projecten in deze categorie.
    </p>
  </div>
</section>

<style>
  .proj-filter { border-color: var(--border); color: var(--fg-soft); background: var(--surface); }
  .proj-filter:hover { border-color: color-mix(in srgb, var(--color-navy) 40%, var(--border)); color: var(--color-navy); }
  .proj-filter.is-active { background: var(--color-navy); border-color: var(--color-navy); color: #fff; }

  /* Blurb reveal op hover (desktop) */
  .proj-blurb { max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.5s ease, opacity 0.5s ease, color 0.5s ease; }
  @media (hover: hover) {
    .proj-card:hover .proj-blurb { max-height: 8rem; opacity: 1; color: rgba(255,255,255,0.85); }
  }
  .proj-card { transition: opacity 0.45s ease, transform 0.45s ease; }
  .proj-card.is-hidden { display: none; }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".proj-filter");
  const cards = document.querySelectorAll<HTMLElement>(".proj-card");
  const empty = document.getElementById("proj-empty");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter;
      filterBtns.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      let shown = 0;
      cards.forEach((c) => {
        const match = f === "Alle" || c.dataset.cat === f;
        c.classList.toggle("is-hidden", !match);
        if (match) shown++;
      });
      empty?.classList.toggle("hidden", shown > 0);
    });
  });
</script>
