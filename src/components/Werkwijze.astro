---
import { werkwijze } from "../data/site";
import SectionHead from "./SectionHead.astro";
---

<section id="werkwijze" class="ctx-light relative overflow-hidden py-24 sm:py-32" style="background:var(--color-steen);">
  <div class="blueprint pointer-events-none absolute inset-y-0 right-0 w-1/2 opacity-60" style="mask-image:linear-gradient(to left, black, transparent);-webkit-mask-image:linear-gradient(to left, black, transparent);"></div>

  <div class="container-edge relative">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20">
      <div class="lg:sticky lg:top-28 lg:self-start">
        <SectionHead index="04" label="Zo werken we" title="Van eerste schets<br />tot sleutel." />
        <p class="lede reveal mt-5 max-w-md">
          Bouwen schept verwachtingen. Daarom houden we het overzichtelijk: vier heldere
          fases, met steeds één vast aanspreekpunt dat u door het hele traject loodst.
        </p>
        <a href="#contact" class="btn btn-navy btn-mag reveal mt-8">Plan een kennismaking</a>
      </div>

      <div class="flex flex-col">
        {
          werkwijze.map((step) => (
            <div class="step reveal group flex gap-6 border-t border-[var(--line)] py-8 transition-colors duration-300 sm:gap-10">
              <div class="display shrink-0 leading-none transition-colors duration-300 group-hover:text-[var(--color-geel-deep)]" style="font-size:clamp(2.4rem,4.5vw,3.4rem);font-weight:600;color:color-mix(in srgb, var(--color-navy) 22%, transparent);">
                {step.no}
              </div>
              <div class="pt-1.5">
                <h3 class="h-card font-semibold">{step.title}</h3>
                <p class="mt-2.5 max-w-md text-[var(--fg-soft)]" style="line-height:1.65;">{step.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
