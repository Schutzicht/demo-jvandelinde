---
import { hero, company } from "../data/site";
const disciplines = ["Restauratie", "Nieuwbouw", "Utiliteit", "Verduurzaming"];
---

<section id="top" class="ctx-dark relative flex min-h-[100svh] flex-col overflow-hidden">
  <!-- Achtergrondbeeld + navy scrim -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[var(--color-navy-deep)]"></div>
    <img
      src="/img/hero.jpg"
      alt="Door Van de Linde gerealiseerd project in Zeeland"
      class="h-full w-full object-cover opacity-80"
      width="1920" height="1080" fetchpriority="high"
    />
    <div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(10,35,66,0.94) 0%, rgba(10,35,66,0.72) 38%, rgba(10,35,66,0.28) 70%, rgba(10,35,66,0.5) 100%);"></div>
    <div class="absolute inset-x-0 bottom-0 h-32" style="background:linear-gradient(to top, rgba(7,28,56,0.85), transparent);"></div>
  </div>

  <div class="relative z-10 flex flex-1 items-center">
    <div class="container-edge w-full pt-32 pb-24 sm:pt-36">
      <div class="max-w-3xl">
        <p class="eyebrow reveal" style="color:var(--color-geel);">{hero.eyebrow}</p>

        <h1 class="display h-hero mt-6 text-white reveal">
          {hero.titleLines.map((line, i) => (
            <span class="block">
              {i === hero.titleLines.length - 1 ? <span style="color:var(--color-geel);">{line}</span> : line}
            </span>
          ))}
        </h1>

        <p class="lede mt-7 max-w-xl reveal" style="color:rgba(244,241,232,0.86);">
          {hero.intro}
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3 reveal">
          <a href={hero.ctaPrimary.href} class="btn btn-geel">{hero.ctaPrimary.label}</a>
          <a href={hero.ctaSecondary.href} class="btn btn-ghost">
            {hero.ctaSecondary.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Disciplines-strip onderaan -->
  <div class="relative z-10 border-t border-white/12">
    <div class="container-edge">
      <div class="flex flex-wrap items-center gap-x-8 gap-y-3 py-5 text-sm font-medium text-white/70">
        <span class="flex items-center gap-2 text-white/90">
          <span class="inline-block h-1.5 w-1.5 rounded-full" style="background:var(--color-geel);"></span>
          {company.tagline}
        </span>
        {disciplines.map((d) => (
          <span class="hidden items-center gap-2 sm:flex">
            <span class="text-white/30">·</span>{d}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
