---
import { hero } from "../data/site";
const lines = ["Wij bouwen voor", "de generaties", "ná ons."];
---

<section id="top" class="js-hero ctx-dark grain relative flex min-h-[100svh] flex-col overflow-hidden">
  <!-- Beeldlaag met parallax -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div class="absolute inset-0 scale-[1.14]" data-parallax="0.08">
      <div class="absolute inset-0 bg-[var(--color-navy-deep)]"></div>
      <img
        src="/img/hero.jpg"
        alt="Door Van de Linde gerealiseerde villa in Zeeland"
        class="h-full w-full object-cover opacity-85"
        width="1760" height="990" fetchpriority="high"
      />
    </div>
    <div class="absolute inset-0" style="background:linear-gradient(105deg, rgba(8,28,56,0.95) 0%, rgba(8,28,56,0.74) 36%, rgba(8,28,56,0.2) 66%, rgba(8,28,56,0.55) 100%);"></div>
    <div class="absolute inset-x-0 bottom-0 h-40" style="background:linear-gradient(to top, rgba(7,24,48,0.92), transparent);"></div>
  </div>

  <!-- Editoriale meta-balk -->
  <div class="relative z-10 pt-28 sm:pt-32">
    <div class="container-edge">
      <div class="flex items-center justify-between border-b border-white/12 pb-4">
        <span class="label" style="color:rgba(244,241,232,0.62);">Bouwbedrijf · sinds 1953</span>
        <span class="label hidden sm:block" style="color:rgba(244,241,232,0.62);">51°30′N&nbsp;&nbsp;3°53′E — Goes, Zeeland</span>
      </div>
    </div>
  </div>

  <!-- Titelblok -->
  <div class="relative z-10 flex flex-1 items-center">
    <div class="container-edge w-full py-12">
      <h1 class="display lh-tight h-hero text-white">
        {lines.map((line, i) => (
          <span class="h-line"><span class="h-line-i" style={`transition-delay:${i * 0.1}s`}>
            {i === lines.length - 1 ? <span style="color:var(--color-geel);">{line}</span> : line}
          </span></span>
        ))}
      </h1>

      <div class="mt-9 flex flex-col gap-7 lg:flex-row lg:items-end lg:justify-between">
        <p class="lede max-w-xl" style="color:rgba(244,241,232,0.85);">{hero.intro}</p>
        <div class="flex flex-wrap items-center gap-3 lg:shrink-0">
          <a href={hero.ctaPrimary.href} class="btn btn-geel btn-mag">{hero.ctaPrimary.label}</a>
          <a href={hero.ctaSecondary.href} class="btn btn-ghost link-sweep">{hero.ctaSecondary.label}</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Onderbalk: scroll-cue + fotobijschrift -->
  <div class="relative z-10 pb-7">
    <div class="container-edge">
      <div class="flex items-end justify-between gap-6">
        <a href="#bedrijf" class="group inline-flex items-center gap-3" aria-label="Scroll naar beneden">
          <span class="grid h-11 w-11 place-items-center rounded-full border border-white/25 text-white/80 transition-colors duration-300 group-hover:border-[var(--color-geel)] group-hover:text-[var(--color-geel)]">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
          </span>
          <span class="label" style="color:rgba(244,241,232,0.6);">Ontdek</span>
        </a>

        <figure class="hidden text-right sm:block">
          <figcaption class="cap" style="color:rgba(244,241,232,0.6);">Plaat 01 — Vrijstaande villa, Middelburg</figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  .h-line { display: block; overflow: hidden; padding-bottom: 0.08em; }
  .h-line-i { display: block; transform: translateY(112%); transition: transform 1.05s var(--ease-out-soft); }
  .hero-go .h-line-i { transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .h-line-i { transform: none !important; }
  }
</style>
