---
import { kernwaarden, company } from "../data/site";
---

<section id="over-ons" class="ctx-dark relative overflow-hidden py-24 sm:py-32">
  <div class="wash wash-navy" style="width:560px;height:560px;top:-180px;right:-160px;"></div>

  <div class="container-edge relative">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="reveal">
        <p class="eyebrow">Over ons</p>
        <h2 class="display h-section mt-5 text-white">
          Drie generaties<br />Zeeuws bouwvakmanschap.
        </h2>
        <p class="lede mt-6" style="color:rgba(244,241,232,0.84);">
          Wat in 1953 begon als een echt Zeeuws aannemersbedrijf, is uitgegroeid tot een
          vertrouwde naam in de provincie. Met inmiddels circa 60 vakmensen, en nog altijd
          met de mentaliteit van een familiebedrijf: betrokken, eerlijk en trots op het werk.
        </p>
        <p class="mt-4" style="color:rgba(244,241,232,0.7);line-height:1.7;">
          We bouwen niet voor het moment, maar voor de generaties die na ons komen. Dat geldt
          voor onze projecten, en net zo goed voor de mensen en relaties om ons heen.
        </p>

        <figure class="mt-8 border-l-2 pl-5" style="border-color:var(--color-geel);">
          <blockquote class="display text-white" style="font-size:clamp(1.3rem,2.4vw,1.7rem);font-weight:500;line-height:1.3;">
            "{company.motto}."
          </blockquote>
          <figcaption class="mt-2 text-sm text-[var(--fg-muted)]">Het motto van Van de Linde</figcaption>
        </figure>
      </div>

      <div class="reveal relative">
        <div class="overflow-hidden rounded-3xl" style="box-shadow:var(--shadow-card);">
          <img
            src="/img/about.jpg"
            alt="Vakmanschap op de bouwplaats bij Van de Linde"
            class="aspect-[4/5] w-full object-cover"
            loading="lazy" width="900" height="1125"
          />
        </div>
        <div class="absolute -bottom-5 -left-5 rounded-2xl px-6 py-5 text-center sm:px-8" style="background:var(--color-geel);color:var(--color-navy-deep);box-shadow:0 20px 40px -16px rgba(0,0,0,0.5);">
          <div class="display leading-none" style="font-size:clamp(2rem,4vw,2.8rem);font-weight:700;">{company.founded}</div>
          <div class="mt-1 text-xs font-semibold uppercase tracking-wider">opgericht in Goes</div>
        </div>
      </div>
    </div>

    <!-- Kernwaarden -->
    <div class="mt-20 sm:mt-24">
      <p class="eyebrow reveal">Waar we voor staan</p>
      <div class="mt-8 grid gap-x-8 gap-y-9 sm:grid-cols-2 lg:grid-cols-5">
        {
          kernwaarden.map((k) => (
            <div class="reveal">
              <div class="flex items-center gap-2.5">
                <span class="inline-block h-2 w-2 rounded-full" style="background:var(--color-geel);"></span>
                <h3 class="text-lg font-semibold text-white" style="font-family:var(--font-display);">{k.title}</h3>
              </div>
              <p class="mt-2 text-sm leading-relaxed" style="color:rgba(244,241,232,0.66);">{k.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
