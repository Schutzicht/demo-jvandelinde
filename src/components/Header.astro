---
import { company, nav } from "../data/site";
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-500">
  <div class="container-edge">
    <div
      id="header-inner"
      class="mt-3 flex items-center justify-between rounded-full border border-transparent px-4 py-2.5 transition-all duration-500 sm:px-5"
    >
      <a href="#top" class="flex items-center" aria-label={`${company.name} home`}>
        <span class="relative block h-8 w-[133px] sm:h-9 sm:w-[150px]">
          <img src="/brand/logo-hero.png" alt={company.name} class="wm wm-light absolute inset-0 h-full w-full object-contain object-left" width="224" height="55" />
          <img src="/brand/logo-ink.png" alt="" aria-hidden="true" class="wm wm-dark absolute inset-0 h-full w-full object-contain object-left" width="224" height="55" />
        </span>
      </a>

      <nav class="hidden items-center gap-0.5 lg:flex">
        {
          nav.map((item) => (
            <a href={item.href} class="nav-link link-sweep px-3.5 py-2 text-sm font-medium transition-colors duration-300">
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <a href={company.phoneHref} class="hdr-phone hidden text-sm font-semibold transition-colors xl:block">
          {company.phone}
        </a>
        <a href="#contact" class="hdr-cta btn-mag inline-flex items-center justify-center rounded-full px-5 py-2.5 text-sm font-semibold transition-all duration-300">
          Offerte aanvragen
        </a>
        <button id="menu-toggle" class="menu-btn grid h-10 w-10 place-items-center rounded-full border transition-colors lg:hidden" aria-label="Menu openen" aria-expanded="false">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobiel menu -->
  <div id="mobile-menu" class="invisible fixed inset-0 z-40 opacity-0 transition-all duration-300 lg:hidden">
    <div class="absolute inset-0 bg-[#0a2342]/55 backdrop-blur-md" data-close></div>
    <nav class="absolute inset-x-4 top-20 rounded-3xl border border-[var(--border)] bg-white p-4 shadow-2xl">
      {
        nav.map((item) => (
          <a href={item.href} data-close class="block rounded-2xl px-4 py-3.5 text-lg font-medium text-[var(--fg)] transition-colors hover:bg-[var(--surface-2)]">
            {item.label}
          </a>
        ))
      }
      <a href="#contact" data-close class="mt-2 block rounded-2xl bg-[var(--color-navy)] px-4 py-3.5 text-center text-lg font-semibold text-white">
        Offerte aanvragen
      </a>
      <div class="mt-3 flex flex-col gap-1.5 border-t border-[var(--border-soft)] px-4 pt-3 text-sm text-[var(--fg-muted)]">
        <a href={company.phoneHref} class="font-semibold text-[var(--fg-soft)]">{company.phone}</a>
        <a href={`mailto:${company.email}`}>{company.email}</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("header-inner");
  const onScroll = () => {
    if (window.scrollY > 24) header?.classList.add("is-scrolled");
    else header?.classList.remove("is-scrolled");
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const open = () => {
    menu?.classList.remove("invisible", "opacity-0");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };
  const close = () => {
    menu?.classList.add("invisible", "opacity-0");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };
  toggle?.addEventListener("click", open);
  menu?.querySelectorAll("[data-close]").forEach((el) => el.addEventListener("click", close));
</script>

<style>
  /* Boven (over donkere hero) */
  .nav-link { color: rgba(255, 255, 255, 0.82); }
  .nav-link:hover { color: #fff; }
  .hdr-phone { color: rgba(255, 255, 255, 0.88); }
  .hdr-phone:hover { color: var(--color-geel); }
  .hdr-cta { background: var(--color-geel); color: var(--color-navy-deep); }
  .hdr-cta:hover { transform: translateY(-1px); background: var(--color-geel-bright); box-shadow: 0 12px 26px -10px rgba(251, 204, 26, 0.6); }
  .menu-btn { border-color: rgba(255, 255, 255, 0.32); color: #fff; }
  .wm-dark { opacity: 0; }
  .wm { transition: opacity 0.4s ease; }

  /* Gescrolld (over lichte content) */
  #header-inner.is-scrolled {
    background: rgba(246, 243, 236, 0.88);
    backdrop-filter: blur(16px);
    border-color: var(--border);
    box-shadow: 0 12px 34px -22px rgba(11, 31, 58, 0.4);
  }
  #header-inner.is-scrolled .nav-link { color: var(--fg-soft); }
  #header-inner.is-scrolled .nav-link:hover { color: var(--color-navy); }
  #header-inner.is-scrolled .hdr-phone { color: var(--fg-soft); }
  #header-inner.is-scrolled .hdr-phone:hover { color: var(--color-navy); }
  #header-inner.is-scrolled .hdr-cta { background: var(--color-navy); color: #fff; }
  #header-inner.is-scrolled .hdr-cta:hover { background: #00468c; }
  #header-inner.is-scrolled .menu-btn { border-color: var(--border); color: var(--color-navy); }
  #header-inner.is-scrolled .wm-light { opacity: 0; }
  #header-inner.is-scrolled .wm-dark { opacity: 1; }
</style>
