---
import { keurmerken } from "../data/site";
---

<section class="ctx-light relative border-y border-[var(--line)] py-12" style="background:var(--color-kalk);">
  <div class="container-edge">
    <div class="flex flex-col items-center gap-8 lg:flex-row lg:items-center lg:gap-14">
      <div class="shrink-0 text-center lg:max-w-[16rem] lg:text-left">
        <div class="flex items-center justify-center gap-3 lg:justify-start">
          <span class="ix">—</span>
          <span class="label">Erkend &amp; gecertificeerd</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-[var(--fg-soft)]">
          Uw garantie op vakwerk, veiligheid en zekerheid, ook na de oplevering.
        </p>
      </div>
      <div class="grid w-full grid-cols-3 items-center gap-3 sm:grid-cols-6 lg:gap-4">
        {
          keurmerken.map((k) => (
            <div class="flex h-[4.5rem] items-center justify-center rounded-[6px] border border-[var(--border)] bg-white px-4 transition-transform duration-300 hover:-translate-y-0.5" title={k.name}>
              <img src={k.file} alt={k.name} class="max-h-11 w-auto max-w-full object-contain" loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
